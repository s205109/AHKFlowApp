    private static void SetAppliesToAllProfiles(HotstringEditModel edit, bool value)
    {
        edit.AppliesToAllProfiles = value;

        if (value)
            edit.ProfileIds.Clear();
    }

    private RenderFragment RenderCategoryEditor(HotstringEditModel edit) =>
