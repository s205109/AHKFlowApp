@using MudBlazor
@inject IReadOnlyList<string> MissingFields

<MudThemeProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6" Class="ml-3">AHKFlowApp</MudText>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                <MudText Typo="Typo.h6">Azure AD configuration is missing</MudText>
            </MudAlert>
            <MudPaper Elevation="2" Class="pa-6">
                <MudText Typo="Typo.body1" Class="mb-4">
                    The following fields in <code>wwwroot/appsettings.json</code> (or your local
                    <code>appsettings.Development.json</code>) are empty:
                </MudText>
                <MudList T="string" Dense="true" Class="mb-4">
                    @foreach (var field in MissingFields)
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Error" IconColor="Color.Error">
                            <code>AzureAd:@field</code>
                        </MudListItem>
                    }
                </MudList>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Copy <code>wwwroot/appsettings.Development.json.example</code> to
                    <code>wwwroot/appsettings.Development.json</code> and fill in your Azure AD values.
                </MudText>
            </MudPaper>
        </MudContainer>
    </MudMainContent>
</MudLayout>

