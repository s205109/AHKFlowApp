    private async Task SaveAsync()
    {
        if (_saving)
            return;

        _saving = true;
        try
        {
            _error = null;
            _triggerError = null;
            _previewTriggerError = null;
            _previewReplacementError = null;
            _previewContextValueError = null;

            await _form.ValidateAsync();
            if (!_form.IsValid)
                return;

            ApiResult<HotstringDto> result = Item.Id is null
                ? await Api.CreateAsync(Item.ToCreateDto(), _cts.Token)
                : await Api.UpdateAsync(Item.Id.Value, Item.ToUpdateDto(), _cts.Token);

            if (!result.IsSuccess)
            {
                if (result.Status == ApiResultStatus.Conflict)
                {
                    _triggerError = ApiErrorMessageFactory.Build(result.Status, result.Problem);
                }
                else if (result.Status == ApiResultStatus.Validation && result.Problem?.Errors is { Count: > 0 } errors)
                {
                    // Route validation failures through the same field-error mapper the preview
                    // panel uses (e.g. a save-time brace-imbalance lands inline on Replacement,
                    // not the generic bottom-of-dialog alert).
                    (_previewTriggerError, _previewReplacementError, _previewContextValueError, _error) = MapFieldErrors(errors);
                }
                else
                {
                    _error = ApiErrorMessageFactory.Build(result.Status, result.Problem);
                }

                return;
            }

            Dialog.Close(DialogResult.Ok(result.Value));
        }
        finally
        {
            _saving = false;
        }
    }

