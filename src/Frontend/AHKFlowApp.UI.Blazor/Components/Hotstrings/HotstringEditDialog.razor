    /// <summary>
    /// Heuristic "looks like AHK code" detector for the Text-kind "Use Script?" suggestion
    /// (spec §54, deferred from Phase 3): a line starting with <c>Send</c>, <c>::</c>, or
    /// <c>#</c>, or any brace character, mirrors the guidance text verbatim. Intentionally
    /// loose — false positives just show a dismissible suggestion, never a hard gate.
    /// </summary>
    private static bool LooksLikeAhkCode(string replacement)
    {
        if (string.IsNullOrEmpty(replacement)) return false;
        if (replacement.Contains('{') || replacement.Contains('}')) return true;

        foreach (string rawLine in replacement.Split('\n'))
        {
            string line = rawLine.TrimStart();
            if (line.StartsWith("Send", StringComparison.Ordinal)
                || line.StartsWith("::", StringComparison.Ordinal)
                || line.StartsWith('#'))
                return true;
        }
        return false;
    }

