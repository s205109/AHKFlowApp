{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "powershell": ".claude/hooks/post-edit-format.ps1",
        "comment": "Auto-format .cs files after edits"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": ".claude/hooks/pre-bash-guard.sh",
        "powershell": "pwsh -NoProfile -NonInteractive -Command \"& (Join-Path ((git rev-parse --show-toplevel).Trim()) 'scripts/agents/invoke-agent-worktree-guard.ps1') -Adapter Copilot\"",
        "comment": "Block destructive bash commands and agent git mutations outside a managed worktree"
      },
      {
        "type": "command",
        "powershell": ".claude/hooks/pre-commit-antipattern.ps1",
        "comment": "Detect bad C# patterns before commit"
      },
      {
        "type": "command",
        "powershell": ".claude/hooks/pre-commit-format.ps1",
        "comment": "Verify formatting before commit"
      }
    ]
  }
}
