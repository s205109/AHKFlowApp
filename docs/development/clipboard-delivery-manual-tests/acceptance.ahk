
AhkFlow_PasteReplacement(text, endChar := "") {
    saved := ClipboardAll()
    A_Clipboard := text
    if !ClipWait(1) {
        A_Clipboard := saved
        return
    }
    Send "^v"
    Sleep 150
    A_Clipboard := saved
    saved := ""
    if (endChar != "")
        SendText endChar
}
